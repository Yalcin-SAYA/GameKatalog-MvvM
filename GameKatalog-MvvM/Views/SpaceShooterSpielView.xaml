<Window x:Class="GameKatalog_MvvM.Views.SpaceShooterSpielView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameKatalog_MvvM.Views"
        mc:Ignorable="d"
        Title="SpaceShooterSpielView" MinWidth="800" MinHeight="450" WindowStartupLocation="CenterScreen">
    
    <Canvas Background="LightBlue"
            Name="MyCanvas"
            KeyDown="onKeyDown"
            KeyUp="onKeyUp"
            Focusable="True">

        <!-- Player -->

        <Rectangle Name="player"
                   Height="50"
                   Width="60"
                   Fill="Yellow"
                   Canvas.Left="222"
                   Canvas.Top="495"/>

        <!-- Score -->

        <Label Name="scoreText"
               Content="Score: 0"
               FontSize="18"
               FontWeight="Bold"
               Foreground="White"/>

        <!-- Damage -->

        <Label Name="damageText"
               Content="Damage: 0"
               FontSize="18"
               FontWeight="Bold"
               Foreground="White"
               Canvas.Top="40"/>

    </Canvas>
</Window>
