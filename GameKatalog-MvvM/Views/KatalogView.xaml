<Window x:Class="GameKatalog_MvvM.Views.KatalogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameKatalog_MvvM.Views"
        mc:Ignorable="d"
        Title="KatalogView"
        MinWidth="800"
        MinHeight="450"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#FF2D2D30">

        <!-- Haupt Border -->

        <Border Background="#FF3E3E42"
                CornerRadius="15"
                Margin="20"
                Padding="20">

            <!-- Layout Grid -->

            <Grid>

                <!-- Reihen -->

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="*"/>

                </Grid.RowDefinitions>

                <!-- Obere Leiste -->

                <Grid Grid.Row="0">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="Auto"/>

                    </Grid.ColumnDefinitions>

                    <!-- Links -->

                    <StackPanel Orientation="Vertical">

                        <Label x:Name="UsernameLabel"
                               Content="Willkommen"
                               Foreground="White"
                               FontSize="16"/>

                        <Label x:Name="GesamtpunkteLabel"
                               Content="Gesamtpunkte: 0"
                               Foreground="White"
                               FontSize="16"/>

                    </StackPanel>

                    <!-- Logout -->

                    <Button Grid.Column="1"
                            Content="Abmelden"
                            Click="LogoutButton_Click"
                            Width="100"
                            Height="30"
                            Background="#FF007ACC"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalAlignment="Right"
                            ToolTip="Vom Konto abmelden">

                        <Button.Style>

                            <Style TargetType="Button">

                                <Setter Property="Template">

                                    <Setter.Value>

                                        <ControlTemplate TargetType="Button">

                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8"
                                                    Padding="5">

                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>

                                            </Border>

                                        </ControlTemplate>

                                    </Setter.Value>

                                </Setter>

                            </Style>

                        </Button.Style>

                    </Button>

                </Grid>

                <!-- Spiele Buttons -->

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                    <!-- Space Shooter -->

                    <Button Content="Space Shooter"
                            Click="SpaceShooterButton_Click"
                            Width="180"
                            Height="45"
                            Margin="0,10"
                            Background="#FF007ACC"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Startet Space Shooter">

                        <Button.Style>

                            <Style TargetType="Button">

                                <Setter Property="Template">

                                    <Setter.Value>

                                        <ControlTemplate TargetType="Button">

                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8"
                                                    Padding="10">

                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>

                                            </Border>

                                        </ControlTemplate>

                                    </Setter.Value>

                                </Setter>

                            </Style>

                        </Button.Style>

                    </Button>

                    <!-- Pacman -->

                    <Button Content="Pacman"
                            Click="PacManButton_Click"
                            Width="180"
                            Height="45"
                            Margin="0,10"
                            Background="#FF007ACC"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Startet Pacman">

                        <Button.Style>

                            <Style TargetType="Button">

                                <Setter Property="Template">

                                    <Setter.Value>

                                        <ControlTemplate TargetType="Button">

                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8"
                                                    Padding="10">

                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>

                                            </Border>

                                        </ControlTemplate>

                                    </Setter.Value>

                                </Setter>

                            </Style>

                        </Button.Style>

                    </Button>

                    <!-- RPG -->

                    <Button Content="RPG"
                            Click="RPGButton_Click"
                            Width="180"
                            Height="45"
                            Margin="0,10"
                            Background="#FF007ACC"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Startet das RPG">

                        <Button.Style>

                            <Style TargetType="Button">

                                <Setter Property="Template">

                                    <Setter.Value>

                                        <ControlTemplate TargetType="Button">

                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8"
                                                    Padding="10">

                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>

                                            </Border>

                                        </ControlTemplate>

                                    </Setter.Value>

                                </Setter>

                            </Style>

                        </Button.Style>

                    </Button>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</Window>